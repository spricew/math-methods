---
import Layout from "@/layouts/Layout.astro";

export function getStaticPaths() {
    return [
        { params: { slug: 'newton-raphson' } },
        { params: { slug: 'bisection' } },
        { params: { slug: 'secant' } },
    ];
}

const { slug } = Astro.params;
---

<Layout title={slug ?? "Método"}>
    <main class="grid grid-cols-2 h-full gap-8 px-24 py-8">
        <section class="flex flex-col gap-4">
            <header class="flex flex-col gap-1">
                <h1 class="text-3xl tracking-tight font-semibold">Parámetros</h1>
                <h1 class="text-3xl tracking-tight font-semibold">Parámetro: este</h1>
                <p>Resuelve ecuaciones</p>
            </header>

            <form class="flex flex-col gap-2">
                <label class="text-base font-medium">COEFICIENTE A</label>
                <input type="text" placeholder="0" class="px-5 py-3 rounded-xl ring ring-outline-variant bg-surface-container-lowest">
                <button class="btn-primary">Calcular</button>
            </form>
        </section>

        <section class="rounded-3xl p-8 bg-surface-container-lowest">
            <header class="flex flex-col gap-2">
                <h1 class="text-xl tracking-tight font-medium">Raíces de la ecuación</h1>
                <div class="grid grid-cols-2 gap-4">
                    <div class="flex flex-col p-6 rounded-2xl bg-primary-background">
                        <span class="text-primary">Raíz x1</span>
                        <span class="text-3xl font-semibold text-primary-container">3</span>
                    </div>
                    <div class="flex flex-col p-6 rounded-2xl bg-primary-background">
                        <span class="text-primary">Raíz x2</span>
                        <span class="text-3xl font-semibold text-primary-container">2</span>
                    </div>
                </div>
            </header>

            <h2 class="text-xl tracking-tight font-semibold">Proceso paso por paso</h2>
        </section>
    </main>
</Layout>